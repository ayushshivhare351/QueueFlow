generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id         String   @id @default(cuid())
  type       String
  status     String
  payload    Json
  retryCount Int      @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}